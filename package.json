{
  "name": "kelendim",
  "version": "2.0.0",
  "description": "Outil expert de dimensionnement solaire photovoltaïque & pompage",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "docs": "typedoc src"
  },
  "dependencies": {
    "zustand": "^4.4.0",
    "axios": "^1.6.0",
    "decimal.js": "^10.4.3",
    "date-fns": "^2.30.0",
    "pdfkit": "^0.13.0",
    "html2pdf.js": "^0.10.1",
    "papaparse": "^5.4.1",
    "qrcode": "^1.5.3",
    "numeral": "^2.0.6"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "vue": "^3.3.0",
    "@types/node": "^20.9.0",
    "eslint": "^8.53.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "prettier": "^3.1.0",
    "typedoc": "^0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
